# ============================================================
# APEX Platform — Environment Configuration for Railway Deploy
# Copy this file to .env and fill in your values.
# On Railway, set these as service variables instead.
# ============================================================

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
# SQLite (default, sufficient for pilot < 10 users):
DATABASE_URL=sqlite:///apex/backend/apex.db
# For Railway volume mount, use:
#   DATABASE_URL=sqlite:////data/apex.db
# For Postgres (future):
#   DATABASE_URL=postgresql://user:pass@host:5432/apex

# ------------------------------------------------------------
# Authentication
# ------------------------------------------------------------
JWT_SECRET_KEY=CHANGE-THIS-TO-A-RANDOM-64-CHAR-SECRET
# Token expiry in minutes (default 480 = 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ------------------------------------------------------------
# LLM Provider — Default (fallback for agents without per-agent config)
# Options: anthropic, gemini, openrouter, ollama
# ------------------------------------------------------------
DEFAULT_LLM_PROVIDER=openrouter
DEFAULT_LLM_MODEL=claude-sonnet-4-6-20260101

# Legacy fallback (used if DEFAULT_LLM_PROVIDER is not set)
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# ------------------------------------------------------------
# API Keys
# ------------------------------------------------------------
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ------------------------------------------------------------
# Per-Agent Model Routing
# Each agent can use a different provider + model.
# If AGENT_{N}_PROVIDER is not set, falls back to DEFAULT_LLM_PROVIDER.
# ------------------------------------------------------------

# Agent 1 — Document Ingestion: pure Python (no LLM needed)

# Agent 2 — Spec Parser: Gemini 2.5 Flash (1M context, cheapest)
AGENT_2_PROVIDER=gemini
AGENT_2_MODEL=gemini-2.5-flash

# Agent 3 — Gap Analysis: Claude Sonnet 4.6
AGENT_3_PROVIDER=openrouter
AGENT_3_MODEL=claude-sonnet-4-6-20260101

# Agent 4 — Quantity Takeoff: Claude Sonnet 4.6
AGENT_4_PROVIDER=openrouter
AGENT_4_MODEL=claude-sonnet-4-6-20260101

# Agent 5 — Labor Productivity: Claude Haiku 4.5 (fastest)
AGENT_5_PROVIDER=openrouter
AGENT_5_MODEL=claude-haiku-4-5-20251001

# Agent 6 — Estimate Assembly: pure Python math + Claude summary
AGENT_6_SUMMARY_PROVIDER=openrouter
AGENT_6_SUMMARY_MODEL=claude-sonnet-4-6-20260101

# Agent 7 — IMPROVE Feedback: Claude Sonnet 4.6
AGENT_7_PROVIDER=openrouter
AGENT_7_MODEL=claude-sonnet-4-6-20260101

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
PORT=8000
LOG_LEVEL=INFO
APEX_DEV_MODE=false

# CORS — comma-separated origins. Railway domain is auto-added.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ------------------------------------------------------------
# File Uploads
# ------------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50

# ------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/minute
RATE_LIMIT_PIPELINE=10/minute

# ------------------------------------------------------------
# Email / SMTP (optional — notifications disabled if not set)
# ------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@apex-platform.com

# ------------------------------------------------------------
# Orchestration (advanced)
# ------------------------------------------------------------
USE_CREWAI_ORCHESTRATOR=false
