# ============================================================
# APEX Platform — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ------------------------------------------------------------
# Legacy / Global fallback (used if per-agent config is absent)
# ------------------------------------------------------------
# LLM_PROVIDER selects the default provider for all agents that
# don't have a per-agent AGENT_{N}_PROVIDER setting.
LLM_PROVIDER=ollama

# Ollama settings (when provider=ollama)
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# Anthropic settings (when provider=anthropic)
ANTHROPIC_MODEL=claude-sonnet-4-6-20260101

# ------------------------------------------------------------
# New default overrides (take priority over LLM_PROVIDER)
# ------------------------------------------------------------
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-6-20260101

# ------------------------------------------------------------
# API Keys
# ------------------------------------------------------------
ANTHROPIC_API_KEY=<your key>
GEMINI_API_KEY=<your key>

# ------------------------------------------------------------
# Per-agent model routing
# Each agent can use a different provider + model.
# If an agent's AGENT_{N}_PROVIDER is not set, it falls back
# to DEFAULT_LLM_PROVIDER, then LLM_PROVIDER.
# ------------------------------------------------------------

# Agent 1 — Document Ingestion: pure Python (no LLM)
# (no config needed)

# Agent 2 — Spec Parser: Gemini 2.5 Flash
# 1M context window, cheapest per-token cost, structured extraction
AGENT_2_PROVIDER=gemini
AGENT_2_MODEL=gemini-2.5-flash

# Agent 3 — Gap Analysis: Claude Sonnet 4.6
# Requires judgment on implied vs. missing construction scope
AGENT_3_PROVIDER=anthropic
AGENT_3_MODEL=claude-sonnet-4-6-20260101

# Agent 4 — Quantity Takeoff: Claude Sonnet 4.6
# Extracts quantities from dense paragraphs with inconsistent units
AGENT_4_PROVIDER=anthropic
AGENT_4_MODEL=claude-sonnet-4-6-20260101

# Agent 5 — Labor Productivity: Claude Haiku 4.5
# Structured CSI code lookup + math; fastest/cheapest Claude tier
AGENT_5_PROVIDER=anthropic
AGENT_5_MODEL=claude-haiku-4-5-20251001

# Agent 6 — Estimate Assembly: pure Python math +
#            Claude Sonnet 4.6 for executive summary only
AGENT_6_SUMMARY_PROVIDER=anthropic
AGENT_6_SUMMARY_MODEL=claude-sonnet-4-6-20260101

# Agent 7 — IMPROVE Feedback: Claude Sonnet 4.6
# Variance analysis + rate adjustment recommendations
AGENT_7_PROVIDER=anthropic
AGENT_7_MODEL=claude-sonnet-4-6-20260101

# ------------------------------------------------------------
# Application settings
# ------------------------------------------------------------
UPLOAD_DIR=./uploads
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
APEX_DEV_MODE=false

# ------------------------------------------------------------
# Orchestration mode toggle
# ------------------------------------------------------------
# Set to true to route pipeline runs through the CrewAI orchestrator.
# Requires: pip install crewai
# Default false — uses the existing sequential AgentOrchestrator unchanged.
# Safe to toggle at runtime; falls back to AgentOrchestrator on any error.
USE_CREWAI_ORCHESTRATOR=false
